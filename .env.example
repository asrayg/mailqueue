# SQLite database location (path is relative to the prisma/ schema directory,
# so "file:./dev.db" creates prisma/dev.db)
DATABASE_URL="file:./dev.db"

# Email address used by Test Mode ("send test email to myself")
TEST_RECIPIENT_EMAIL="you@example.com"

# Where persistent Playwright browser profiles are stored
BROWSER_PROFILES_DIR="./browser-profiles"

# Where uploaded CSVs and attachments are stored
UPLOADS_DIR="./uploads"

# Run Playwright with a visible browser window. Keep "false" headless OFF for
# email providers, which often flag headless automation. true = visible.
PLAYWRIGHT_HEADED="true"
